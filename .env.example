# Convex Auth + Providers
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Convex
CONVEX_DEPLOYMENT=your-deployment-name
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# OpenAI (for Clarity Engine, Whisper, DALL-E)
OPENAI_API_KEY=sk-xxx

# Cloudflare R2 (worker uploads final MP4; keys only on the worker host in production)
R2_ACCOUNT_ID=xxx
R2_ACCESS_KEY_ID=xxx
R2_SECRET_ACCESS_KEY=xxx
R2_BUCKET_NAME=mindra-videos-beta
# Public origin for objects (custom domain or https://pub-xxxxx.r2.dev), no trailing slash
R2_PUBLIC_BASE_URL=https://videos.example.com

# Remote render worker (omit for local ffmpeg in Next)
RENDER_WORKER_URL=https://render.example.com
RENDER_WORKER_SECRET=long-random-shared-with-worker

# Convex dashboard env: RENDER_WEBHOOK_SECRET (worker + Convex only, not Vercel)
# Worker env: CONVEX_SITE_URL=https://your-deployment.convex.site

# Telegram Bot (notifications)
TELEGRAM_BOT_TOKEN=xxx

# OneSignal (push notifications)
NEXT_PUBLIC_ONESIGNAL_APP_ID=xxx
ONESIGNAL_REST_API_KEY=xxx

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
